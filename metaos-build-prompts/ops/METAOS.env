# METAOS runtime defaults
# Paths are resolved relative to repository root unless absolute.

METAOS_ROOT=..
METAOS_INSTANCE_ID=default
METAOS_INSTANCES_DIR=instances
METAOS_ENTRYPOINT=runtime/orchestrator.py
METAOS_PYTHON=python
METAOS_RUNTIME_ARGS=
