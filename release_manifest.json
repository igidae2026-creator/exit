{
  "version": 1,
  "release_includes": [
    "app",
    "artifact",
    "domains",
    "docs",
    "genesis",
    "metaos",
    "metaos_a",
    "metaos_b",
    "metaos_c",
    "observer",
    "ops",
    "runtime",
    "scripts",
    "signal",
    "strategy",
    "tests",
    "validation",
    "README.md",
    "RUNBOOK.md",
    "pyproject.toml",
    "setup.py"
  ],
  "exclude_parts": ["__pycache__", ".git", ".venv", "dist", "snapshots"],
  "exclude_suffixes": [".pyc", ".bak"],
  "ownership": [
    {"path":"app","classification":"compatibility_shim","canonical_owner":"metaos.cli","public":true,"packaged":true,"release_included":true,"deprecation_status":"active-shim","rationale":"Legacy app CLI forwards to canonical metaos CLI."},
    {"path":"artifact","classification":"canonical","canonical_owner":"artifact","public":true,"packaged":true,"release_included":true,"deprecation_status":"none","rationale":"Append-only artifact archive and lineage registry."},
    {"path":"core","classification":"compatibility_shim","canonical_owner":"metaos.core","public":false,"packaged":false,"release_included":false,"deprecation_status":"deprecated-shim","rationale":"Deprecated import bridge kept for backward compatibility."},
    {"path":"docs","classification":"canonical","canonical_owner":"docs","public":true,"packaged":false,"release_included":true,"deprecation_status":"none","rationale":"Operator and architecture specifications."},
    {"path":"domains","classification":"canonical","canonical_owner":"domains","public":true,"packaged":true,"release_included":true,"deprecation_status":"none","rationale":"Domain contracts and implementations."},
    {"path":"ecosystem","classification":"repo_only","canonical_owner":"ecosystem","public":false,"packaged":false,"release_included":false,"deprecation_status":"internal","rationale":"Research/support simulations not used by released CLI contract."},
    {"path":"evolution","classification":"compatibility_shim","canonical_owner":"metaos.runtime","public":false,"packaged":false,"release_included":false,"deprecation_status":"deprecated-shim","rationale":"Deprecated surface redirected to runtime owners."},
    {"path":"federation","classification":"runtime_helper","canonical_owner":"federation","public":false,"packaged":false,"release_included":false,"deprecation_status":"internal","rationale":"Internal federation helpers consumed by runtime modules."},
    {"path":"genesis","classification":"canonical","canonical_owner":"genesis","public":true,"packaged":true,"release_included":true,"deprecation_status":"none","rationale":"Kernel-level invariant and replay enforcement."},
    {"path":"kernel","classification":"compatibility_shim","canonical_owner":"metaos.kernel","public":false,"packaged":false,"release_included":false,"deprecation_status":"deprecated-shim","rationale":"Deprecated import bridge only."},
    {"path":"loop","classification":"runtime_helper","canonical_owner":"loop","public":false,"packaged":false,"release_included":false,"deprecation_status":"internal","rationale":"Exploration loop model helpers."},
    {"path":"metaos","classification":"canonical","canonical_owner":"metaos","public":true,"packaged":true,"release_included":true,"deprecation_status":"none","rationale":"Primary public package and CLI."},
    {"path":"metaos-build-prompts","classification":"repo_only","canonical_owner":"metaos-build-prompts","public":false,"packaged":false,"release_included":false,"deprecation_status":"internal","rationale":"Prompt-building assets for repository contributors."},
    {"path":"metaos_a","classification":"canonical","canonical_owner":"metaos_a","public":true,"packaged":true,"release_included":true,"deprecation_status":"none","rationale":"Domain engine layer."},
    {"path":"metaos_b","classification":"canonical","canonical_owner":"metaos_b","public":true,"packaged":true,"release_included":true,"deprecation_status":"none","rationale":"Resource/strategy management layer."},
    {"path":"metaos_c","classification":"canonical","canonical_owner":"metaos_c","public":true,"packaged":true,"release_included":true,"deprecation_status":"none","rationale":"Civilization-level layer."},
    {"path":"observer","classification":"canonical","canonical_owner":"observer","public":true,"packaged":false,"release_included":true,"deprecation_status":"none","rationale":"Read-only projections used by CLI status commands."},
    {"path":"ops","classification":"release_only","canonical_owner":"ops","public":true,"packaged":false,"release_included":true,"deprecation_status":"none","rationale":"Operational scripts and unit templates."},
    {"path":"runtime","classification":"canonical","canonical_owner":"runtime","public":true,"packaged":true,"release_included":true,"deprecation_status":"none","rationale":"Runtime orchestration and long-run validators."},
    {"path":"scripts","classification":"release_only","canonical_owner":"scripts","public":true,"packaged":false,"release_included":true,"deprecation_status":"none","rationale":"Release build/validation tooling."},
    {"path":"signal","classification":"runtime_helper","canonical_owner":"signal","public":false,"packaged":false,"release_included":true,"deprecation_status":"internal","rationale":"Pressure/signal helpers consumed by runtime."},
    {"path":"strategy","classification":"runtime_helper","canonical_owner":"strategy","public":false,"packaged":false,"release_included":true,"deprecation_status":"internal","rationale":"Strategy helper modules used by orchestrator."},
    {"path":"tests","classification":"test_only","canonical_owner":"tests","public":false,"packaged":false,"release_included":true,"deprecation_status":"none","rationale":"Regression and acceptance verification suite."},
    {"path":"validation","classification":"canonical","canonical_owner":"validation","public":true,"packaged":true,"release_included":true,"deprecation_status":"none","rationale":"Invariants and system-boundary validators."}
  ]
}
